[package]
url = https://github.com/adityatiwari/zeek-ev-dns-tunnel
version = 1.0.0
zeek_version = >=5.0.0
description = Zero-training DNS tunnel detector using compositional Ev statistic.
              Detects dnscat2, iodine, dns2tcp, CobaltStrike, ozymandns,
              tcp-over-dns, DNS-shell, tuns, dnspot, AndIodine.
              F1=1.000 vs Suricata ET Open F1=0.571 on GraphTunnel benchmark.
              Zero signatures. Zero training data. Self-calibrating.
tags = dns, tunnel, detection, anomaly, exfiltration
script_dir = scripts
